<div class="card">
    <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-start mb-2">
            <h2 class="fs-5 mb-0">{{ review.companyName }}</h2>
            <span class="text-muted small text-nowrap">
                {{ review.createdAt.format('Y-m-d') }}
            </span>
        </div>

        <div class="d-flex align-items-center gap-1 mb-3">
            {% for i in 1..5 %}
                <span class="star-rating-result {% if i <= review.rating.value %}active{% endif %}">★</span>
            {% endfor %}
        </div>

        {% if review.reviewText %}
            <p class="mb-3 text-body">
                {{ review.reviewText }}
            </p>
        {% endif %}

        <div class="d-flex justify-content-end gap-2">
            {% if show_actions is not defined or show_actions %}
                <a href="{{ path('review_show', {id: review.id}) }}" class="btn btn-outline-secondary btn-sm">
                    {{ 'common.show'|trans }}
                </a>
            {% endif %}
            {% if show_back is defined and show_back %}
                <a href="{{ path('review_list') }}" class="btn btn-outline-secondary btn-sm">
                    {{ 'common.back_to_list'|trans }}
                </a>
            {% endif %}
        </div>

    </div>
</div>


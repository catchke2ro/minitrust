{% extends 'base.html.twig' %}

{% block title %}{{ 'page.review.list.title'|trans }}{% endblock %}

{% block body %}
    <div class="container py-5" style="max-width: 720px;">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>{{ 'page.review.list.heading'|trans }}</h1>
            <a href="{{ path('review_create') }}" class="btn btn-primary">
                {{ 'common.create_new_review'|trans }}
            </a>
        </div>

        {% include 'widget/flash_messages.html.twig' %}

        <p class="text-muted small mb-3">{{ 'page.review.list.total'|trans({'%count%': reviews|length}) }}</p>

        <div class="d-flex flex-column gap-3">
            {% for review in reviews %}
                {{ include('review/_card.html.twig') }}
            {% endfor %}
        </div>
    </div>
{% endblock %}

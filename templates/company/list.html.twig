{% extends 'base.html.twig' %}

{% block title %}{{ 'page.company.list.title'|trans }}{% endblock %}

{% block body %}
    <div class="container py-5" style="max-width: 720px;">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>{{ 'page.company.list.heading'|trans }}</h1>
        </div>

        {% include 'widget/flash_messages.html.twig' %}

        <p class="text-muted small mb-3">
            {{ 'page.company.list.total'|trans({'%count%': stats|length}) }}
        </p>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">{{ 'page.company.list.column.company'|trans }}</th>
                    <th scope="col" class="text-center">{{ 'page.company.list.column.review_count'|trans }}</th>
                    <th scope="col" class="text-center">{{ 'page.company.list.column.average_rating'|trans }}</th>
                </tr>
                </thead>
                <tbody>
                {% for stat in stats %}
                    <tr>
                        <td class="text-muted small">{{ loop.index }}</td>
                        <td>
                            <strong>{{ stat.companyName }}</strong>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-secondary">{{ stat.reviewCount }}</span>
                        </td>
                        <td class="text-center">
                            {% set avg = stat.averageRating %}
                            <span class="badge {% if avg >= 4 %}bg-success{% elseif avg >= 3 %}bg-warning text-dark{% else %}bg-danger{% endif %}">
                                ★ {{ avg|number_format(2) }}
                            </span>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

